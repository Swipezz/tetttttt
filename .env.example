# ============================================================
# .env.example — Salin ke .env dan isi nilainya
# File .env TIDAK boleh di-commit ke Git (ada di .gitignore)
# ============================================================

# ── Database Target (Kriteria 4: Load ke DB) ────────────────
# Opsi 1: Aiven PostgreSQL (production)
# postgres:// CLICK_TO:REVEAL_PASSWORD@pg-39227133-etl-pricing-strategy.a.aivencloud.com:10451/defaultdb?sslmode=require
# Opsi 2: SQLite lokal (development, default jika tidak diset)
# DATABASE_URL=sqlite:///data/warehouse/game_price_etl.db

# ── Kurs Mata Uang ──────────────────────────────────────────
IDR_PER_USD=16250

# ── HTTP Scraping ───────────────────────────────────────────
EXTRACT_TIMEOUT=15
MAX_RETRIES=3

# ── Logging ─────────────────────────────────────────────────
LOG_LEVEL=INFO

# ── Direktori (opsional, default dari config/settings.py) ───
# RAW_DATA_DIR=data/raw
# PROCESSED_DIR=data/processed
# WAREHOUSE_DIR=data/warehouse
# OUTPUTS_DIR=outputs
